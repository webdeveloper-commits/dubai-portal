[Unit]
Description=Elysian Admin Panel (Flask)
After=network.target

[Service]
WorkingDirectory=/var/www/dubai-portal/extractor
EnvironmentFile=/var/www/dubai-portal/extractor/.env
ExecStart=/var/www/dubai-portal/extractor/venv/bin/gunicorn --workers 1 --bind 127.0.0.1:5001 --timeout 120 admin:app
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
